# AI Assistant Configuration
# Copy this to .env and fill in your values

# Platform: telegram (default), slack, discord, teams
# Auto-detected from available tokens if not set.
# PLATFORM=telegram

# Telegram Bot
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=

# Slack Bot (Socket Mode - no public endpoint needed)
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN=xapp-your-token
# SLACK_ALLOWED_USERS=U01234ABCDE,U56789FGHIJ

# Timezone (used by scheduler and briefings)
TIMEZONE=America/New_York

# Calendar account for context injection (optional)
CALENDAR_ACCOUNT=

# Scheduler (set to false to disable scheduled tasks)
SCHEDULER_ENABLED=true

# Voice interface (optional - ElevenLabs)
HTTP_PORT=3030
HTTP_BEARER_TOKEN=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Video analysis (optional - Gemini)
GOOGLE_API_KEY=

# OpenAI (optional - Whisper STT)
OPENAI_API_KEY=
