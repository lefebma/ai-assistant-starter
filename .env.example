# AI Assistant Configuration
# Copy this to .env and fill in your values

# Platform: telegram (default), slack, discord, teams
# Auto-detected from available tokens if not set.
# PLATFORM=telegram

# Telegram Bot
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=

# Slack Bot (Socket Mode - no public endpoint needed)
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN=xapp-your-token
# SLACK_ALLOWED_USERS=U01234ABCDE,U56789FGHIJ

# Which Claude model the assistant runs on: sonnet (default), opus, or haiku.
# Opus is the most capable and the most expensive; haiku is the fastest and
# cheapest. Prefer these short names over a specific version like
# claude-opus-4-6, which can stop working when the engine updates.
# AGENT_MODEL=sonnet

# --- Choose your engine (LLM-agnostic runtime) ---
# AGENT_RUNTIME picks which engine powers replies:
#   claude  (default) = the Claude Agent SDK on your Claude subscription
#   ai-sdk            = a provider-agnostic runtime that calls a model API directly
# AGENT_RUNTIME=claude
#
# AGENT_RUNTIME_CRON runs scheduled/unattended work (e.g. the nightly reflection)
# on a different engine than chat. Defaults to the same as AGENT_RUNTIME.
# AGENT_RUNTIME_CRON=claude
#
# When AGENT_RUNTIME=ai-sdk, pick the provider + model. AI_MODEL is REQUIRED for
# every provider except anthropic. Set the matching API key (OPENAI_API_KEY and
# GOOGLE_API_KEY are further down; ANTHROPIC_API_KEY is below).
# AI_PROVIDER=anthropic          # anthropic | openai | google
# AI_MODEL=                      # e.g. claude-sonnet-5 | gpt-5 | gemini-2.5-pro
# AI_BASE_URL=                   # optional: point AI_PROVIDER=openai at any
#                                # OpenAI-compatible endpoint (Ollama, vLLM, LM Studio)
# AI_HISTORY_MAX_BYTES=200000    # optional: cap per-conversation history re-sent
#                                # each turn (ai-sdk runtime) to control cost
#
# ANTHROPIC_API_KEY does double duty: it's the key for AI_PROVIDER=anthropic, and
# on the claude runtime it enables subscription overflow — if your subscription
# usage window is exhausted mid-conversation, the assistant finishes the reply on
# API billing (and tells you) instead of stalling. Leave unset to disable both.
# ANTHROPIC_API_KEY=

# Timezone (used by scheduler and briefings)
TIMEZONE=America/New_York

# Calendar account for context injection (optional)
CALENDAR_ACCOUNT=

# Scheduler (set to false to disable scheduled tasks)
SCHEDULER_ENABLED=true

# Voice interface (optional - ElevenLabs)
HTTP_PORT=3030
HTTP_BEARER_TOKEN=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Video analysis (optional - Gemini)
GOOGLE_API_KEY=

# OpenAI (optional - Whisper STT)
OPENAI_API_KEY=
