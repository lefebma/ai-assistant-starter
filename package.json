{
  "name": "ai-assistant-starter",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts",
    "schedule": "node dist/src/schedule-cli.js",
    "seed-jobs": "tsx src/seed-jobs.ts",
    "dream": "node dist/src/dreaming/index.js",
    "dream:dev": "tsx src/dreaming/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.98",
    "@ai-sdk/google": "^3.0.95",
    "@ai-sdk/mcp": "^1.0.63",
    "@ai-sdk/openai": "^3.0.86",
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@elevenlabs/client": "^1.3.0",
    "ai": "^6.0.230",
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^5.0.0",
    "form-data": "^4.0.5",
    "grammy": "^1.41.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "marked": "^18.0.2",
    "playwright": "^1.60.0-alpha-1774999321000",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
